<UserControl
    x:Class="ComfyUIHelper.Controls.UpscaleImagePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ComfyUIHelper.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:viewModels="clr-namespace:ComfyUIHelper.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:UpscaleImagePanelViewModel}"
    d:DesignWidth="1200"
    Background="{StaticResource DarkBackgroundBrush}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2">

            <local:FileDropArea
                Margin="10,2"
                FilePath="{Binding CurrentWorkflowPath}"
                PlaceholderText="json file drop here.">
                <local:FileDropArea.FileTemplate>
                    <DataTemplate DataType="{x:Type system:String}">
                        <TextBlock
                            FontSize="{StaticResource CommonFontSize}"
                            Foreground="{StaticResource CommonForegroundBrush}"
                            Text="{Binding}" />
                    </DataTemplate>
                </local:FileDropArea.FileTemplate>
            </local:FileDropArea>

            <UniformGrid Columns="3">
                <!-- Checkpoint -->
                <local:FileSuggestBox
                    Label="Chkpt: "
                    SelectedPath="{Binding LoadCheckPoint}"
                    SourceDirectoryPath="{Binding ModelDirectoryPath}" />

                <!-- vae -->
                <local:FileSuggestBox
                    Margin="10,0"
                    Label="Vae: "
                    SelectedPath="{Binding LoadVae}"
                    SourceDirectoryPath="{Binding VaeDirectoryPath}" />

                <!-- upscaler -->
                <local:FileSuggestBox
                    Label="Upscaler: "
                    SelectedPath="{Binding LoadUpScaleModel}"
                    SourceDirectoryPath="{Binding UpscalerDirectoryPath}" />
            </UniformGrid>

            <UniformGrid Margin="0,10" Columns="3">
                <local:LoraSettingUnit
                    SelectedPath="{Binding LoadLora1}"
                    SourceDirectoryPath="{Binding LoraDirectoryPath}"
                    Value="{Binding Lora1Strength}" />

                <local:LoraSettingUnit
                    Margin="10,0"
                    SelectedPath="{Binding LoadLora2}"
                    SourceDirectoryPath="{Binding LoraDirectoryPath}"
                    Value="{Binding Lora2Strength}" />

                <local:LoraSettingUnit
                    SelectedPath="{Binding LoadLora3}"
                    SourceDirectoryPath="{Binding LoraDirectoryPath}"
                    Value="{Binding Lora3Strength}" />
            </UniformGrid>
        </StackPanel>

        <Grid
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <local:CustomTextBox
                Grid.Row="0"
                Grid.Column="0"
                Header="Positive Prompt"
                Text="{Binding PositivePrompt, UpdateSourceTrigger=PropertyChanged}" />

            <local:CustomTextBox
                Grid.Row="1"
                Grid.Column="0"
                Height="90"
                Header="Negative Prompt"
                Text="{Binding NegativePrompt, UpdateSourceTrigger=PropertyChanged}" />

            <!-- image drop area -->
            <local:FileDropArea
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1"
                MinWidth="300"
                FilePath="{Binding CurrentImagePath}"
                PlaceholderText="Image file drop here.">
                <local:FileDropArea.FileTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Image
                                MaxWidth="400"
                                MaxHeight="300"
                                Source="{Binding Converter={StaticResource ImagePathToBitmapSourceConverter}}" />
                            <TextBlock
                                MaxWidth="350"
                                HorizontalAlignment="Center"
                                FontSize="{StaticResource CommonFontSize}"
                                Foreground="{StaticResource CommonForegroundBrush}"
                                Text="{Binding}"
                                TextWrapping="WrapWithOverflow" />
                        </StackPanel>
                    </DataTemplate>
                </local:FileDropArea.FileTemplate>
            </local:FileDropArea>
        </Grid>

        <StackPanel Grid.Row="2" Grid.Column="0">
            <local:DoubleNumericInput
                VerticalAlignment="Top"
                Label="Denoise"
                MaxValue="3.0"
                MinValue="0"
                Step="0.01"
                Value="{Binding Denoise, UpdateSourceTrigger=PropertyChanged}" />

            <local:LabeledNumericInput
                VerticalAlignment="Top"
                Label="Seed"
                Steps="1"
                Value="{Binding Seed, UpdateSourceTrigger=PropertyChanged}" />

            <local:LabeledNumericInput
                VerticalAlignment="Top"
                Label="Issue Number"
                Steps="1"
                Value="{Binding IssueNumber, UpdateSourceTrigger=PropertyChanged}" />

            <local:DoubleNumericInput
                VerticalAlignment="Top"
                Label="UpScaleBy"
                MaxValue="4.0"
                MinValue="1.0"
                Step="0.05"
                Value="{Binding UpScaleBy, UpdateSourceTrigger=PropertyChanged}" />

            <local:CustomTextBox Header="File name prefix" Text="{Binding FileNamePrefix, UpdateSourceTrigger=PropertyChanged}" />

            <Button
                Width="250"
                HorizontalAlignment="Left"
                Command="{Binding SendRequestAsyncCommand}">
                <TextBlock Text="Generate" />
            </Button>
        </StackPanel>

    </Grid>
</UserControl>