<UserControl
    x:Class="ComfyUIHelper.Controls.UpscaleImagePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ComfyUIHelper.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ComfyUIHelper.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:UpscaleImagePanelViewModel}"
    d:DesignHeight="400"
    d:DesignWidth="800"
    Background="{StaticResource DarkBackgroundBrush}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <local:CustomTextBox
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Header="Positive Prompt"
            Text="{Binding PositivePrompt, UpdateSourceTrigger=PropertyChanged}" />

        <local:CustomTextBox
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Height="120"
            Header="Negative Prompt"
            Text="{Binding NegativePrompt, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel
            Grid.Row="2"
            Grid.Column="0"
            Orientation="Horizontal">
            <local:LabeledNumericInput
                VerticalAlignment="Top"
                Label="Denoise"
                Steps="1"
                Value="{Binding Denoise, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

    </Grid>
</UserControl>