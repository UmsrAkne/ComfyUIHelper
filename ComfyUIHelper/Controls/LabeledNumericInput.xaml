<UserControl
    x:Class="ComfyUIHelper.Controls.LabeledNumericInput"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ComfyUIHelper.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
        <TextBlock
            Margin="10,0"
            VerticalAlignment="Center"
            FontSize="{StaticResource CommonFontSize}"
            Foreground="{StaticResource CommonForegroundBrush}"
            Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=Label}" />

        <md:NumericUpDown
            FontSize="{StaticResource CommonFontSize}"
            Foreground="{StaticResource CommonForegroundBrush}"
            ValueStep="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=Steps}"
            Value="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=Value}">
            <md:NumericUpDown.LayoutTransform>
                <ScaleTransform ScaleX="1.25" ScaleY="1.25" />
            </md:NumericUpDown.LayoutTransform>
        </md:NumericUpDown>
    </StackPanel>
</UserControl>