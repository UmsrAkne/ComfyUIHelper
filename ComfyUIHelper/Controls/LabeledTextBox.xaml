<UserControl
    x:Class="ComfyUIHelper.Controls.LabeledTextBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ComfyUIHelper.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <Border
        Padding="8"
        Background="{StaticResource MiddleBackgroundBrush}"
        CornerRadius="{StaticResource CommonCornerRadius}">
        <Grid x:Name="LayoutRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Margin="0,0,10,0"
                Padding="2"
                FontSize="{StaticResource CommonFontSize}"
                Foreground="{StaticResource CommonForegroundBrush}"
                Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=Label}" />

            <TextBox
                Grid.Column="1"
                Padding="2"
                FontSize="{StaticResource CommonFontSize}"
                Foreground="{StaticResource CommonForegroundBrush}"
                Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=Text}" />
        </Grid>

    </Border>
</UserControl>