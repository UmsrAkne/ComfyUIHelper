<UserControl
    x:Class="ComfyUIHelper.Controls.LoraSettingUnit"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ComfyUIHelper.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <!-- LoRA is ignored if the strength is 0. -->
                    <DataTrigger Binding="{Binding Value, ElementName=Root}" Value="0.00">
                        <Setter Property="Opacity" Value="0.4" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>

        <Border Background="{StaticResource ControlBaseBackgroundBrush}" CornerRadius="{StaticResource CommonCornerRadius}">
            <StackPanel>
                <local:FileSuggestBox
                    FilterExtensions="safetensors"
                    Label="Lora: "
                    SelectedPath="{Binding SelectedPath, ElementName=Root}"
                    SourceDirectoryPath="{Binding SourceDirectoryPath, ElementName=Root}" />

                <local:DoubleNumericInput
                    Margin="0,5"
                    Label="Strength: "
                    Step="0.01"
                    Value="{Binding Value, ElementName=Root}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>