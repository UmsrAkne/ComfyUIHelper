<UserControl
    x:Class="ComfyUIHelper.Controls.FileDropArea"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ComfyUIHelper.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="100"
    d:DesignWidth="300"
    AllowDrop="True"
    DragOver="OnDragOver"
    Drop="OnDrop"
    mc:Ignorable="d">
    <Grid>
        <Border
            Padding="10"
            Background="Transparent"
            BorderBrush="Gray"
            BorderThickness="2"
            CornerRadius="5">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="{StaticResource CommonFontSize}"
                    Foreground="{StaticResource CommonForegroundBrush}"
                    Text="FIle drop here." />
                <TextBlock
                    Margin="0,5,0,0"
                    HorizontalAlignment="Center"
                    FontSize="{StaticResource CommonFontSize}"
                    Foreground="{StaticResource CommonForegroundBrush}"
                    Text="{Binding FilePath, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>