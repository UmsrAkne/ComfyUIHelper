<UserControl
    x:Class="ComfyUIHelper.Controls.FileSuggestBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ComfyUIHelper.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ComfyUIHelper.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:FileSuggestBoxViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <Border
        Padding="10,4,4,4"
        Background="{StaticResource ControlBaseBackgroundBrush}"
        CornerRadius="{StaticResource CommonCornerRadius}">
        <Grid x:Name="InternalRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Margin="3,0"
                VerticalAlignment="Center">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="{StaticResource CommonFontSize}"
                    Foreground="{StaticResource CommonForegroundBrush}"
                    Text="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}, Path=Label}" />
            </Border>

            <TextBox
                x:Name="SearchBox"
                Grid.Column="1"
                Background="{StaticResource DarkBackgroundBrush}"
                FontSize="{StaticResource CommonFontSize}"
                Foreground="{StaticResource CommonForegroundBrush}"
                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}" />

            <Popup
                AllowsTransparency="True"
                IsOpen="{Binding IsSuggestionOpen}"
                Placement="Bottom"
                PlacementTarget="{Binding ElementName=SearchBox}"
                PopupAnimation="Fade"
                StaysOpen="False">

                <Border
                    Width="{Binding ElementName=SearchBox, Path=ActualWidth}"
                    MaxHeight="200"
                    Background="{StaticResource MiddleBackgroundBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CommonCornerRadius}">

                    <ListBox
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding Suggestions}"
                        SelectedItem="{Binding SelectedFile}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Padding="5,0"
                                    Foreground="{StaticResource CommonForegroundBrush}"
                                    Text="{Binding}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>